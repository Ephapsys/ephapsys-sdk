# Ephapsys Ops Center production API base URL.
# Use this production endpoint for the public SDK and samples.
AOC_BASE_URL=https://api.ephapsys.com

# Organization ID for your Ephapsys account.
# Get this from the Ephapsys web app after signing up and creating your organization.
AOC_ORG_ID=org_xxxxxxxxx

# Provisioning token used by the SDK to exchange for a short-lived device token at runtime.
# Generate this in the Ephapsys web app under your organization token/settings area.
AOC_PROVISIONING_TOKEN=boot_xxxxxxxxx

# Modulation token used by ./push.sh to register models, run modulation, and create templates.
# Generate this in the Ephapsys web app under your organization token/settings area.
AOC_MODULATION_TOKEN=mod_xxxxxxxxx

# Optional A2A token used only for agent-to-agent messaging.
# Generate this in the Ephapsys web app only if you plan to use A2A flows.
# AOC_A2A_TOKEN=a2a_xxxxxxxxx

# Optional HMAC secret used only when signed A2A mode is enabled.
# This is backend/operator-configured rather than required for normal HelloWorld onboarding.
# A2A_HMAC_SECRET=replace_with_org_secret

# Language model template ID used by the HelloWorld sample.
# Leave this blank on first run if you want ./quickstart.sh to prefer an existing starter template
# and only fall back to ./push.sh if one is not available yet.
MODEL_TEMPLATE_ID=

# Agent template ID used by the HelloWorld runtime sample.
# Leave this blank on first run if you want ./quickstart.sh to prefer an existing starter template
# and only fall back to ./push.sh if one is not available yet.
AGENT_TEMPLATE_ID=

# Hugging Face token used when registering or downloading provider-backed model templates.
# Leave commented out for public repos such as the default HelloWorld starter model.
# HF_TOKEN=

# Personalization anchor for the local runtime.
# Use 'none' for local development; use tpm, tee, dsim, or hsm for stronger production anchors.
PERSONALIZE_ANCHOR=none # dev/demo only; for production use tpm,  tee, or hsm

# Optional HelloWorld bootstrap knobs used by ./push.sh
# HELLOWORLD_MODEL_REPO=Qwen/Qwen2.5-0.5B-Instruct
# HELLOWORLD_MODEL_REVISION=main
# HELLOWORLD_MODEL_NAME=HelloWorld Starter Model
# AGENT_TEMPLATE_NAME=HelloWorld Agent Template

# If PERSONALIZE_ANCHOR=hsm, set the Cloud KMS details below.
# HSM_KMS_KEY=projects/my-project/locations/us-central1/keyRings/agents/cryptoKeys/helloworld/cryptoKeyVersions/1
# HSM_KMS_ENDPOINT=privatekms.googleapis.com
# HSM_KMS_CREDENTIALS=/absolute/path/to/service-account.json
# HSM_SLOT=projects/my-project/locations/us-central1/keyRings/agents
# HSM_KEY_LABEL=helloworld
# HSM_KMS_LOCATION=us-central1
# HSM_KMS_KEY_RING=agents
# HSM_KMS_KEY_NAME=helloworld
# HSM_KMS_USE_HSM=1
# COMPUTE_SERVICE_ACCOUNT=project-number-compute@developer.gserviceaccount.com
# To use another HSM vendor, configure HSM_HELPER instead of the KMS variables.

# Optional GGUF/llama.cpp runtime knobs (uncomment if your language model artifact is .gguf)
# MODEL_RUNTIME=gguf
# AOC_LLAMA_CPP_CLI=llama-cli
# AOC_GGUF_CTX=2048
# AOC_GGUF_MAX_NEW_TOKENS=256

# Optional A2A knobs (for commented A2A sample block in helloworld_agent.py)
# AOC_A2A_TOKEN=a2a_xxxxxxxxx
# A2A_PEER_AGENT_ID=agent_peer
# A2A_CORRELATION_PREFIX=hello

# Bootstrap token workflow:
# 1) Retrieve AOC_PROVISIONING_TOKEN from AOC frontend/API during provisioning.
# 2) SDK exchanges it for a short-lived device-bound token at runtime.
