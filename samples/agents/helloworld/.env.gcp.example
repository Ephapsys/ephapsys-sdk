# Copy to .env.gcp and fill in for your own GCP environment.

PROJECT_ID=your-gcp-project-id
ZONE=your-gcp-zone
MACHINE_TYPE=e2-standard-4
DISK_SIZE=50GB
IMAGE_FAMILY=ubuntu-2204-lts
IMAGE_PROJECT=ubuntu-os-cloud
INSTANCE_PREFIX=hello-agent

# Optional interactive behavior
INTERACTIVE=1

# CPU/GPU VM settings
USE_GPU=0
GPU_TYPE=t4
GPU_MACHINE_TYPE=n1-standard-8
GPU_COUNT=1
GPU_IMAGE_FAMILY=pytorch-2-7-cu128-ubuntu-2204-nvidia-570

# SDK package source for the remote VM: pypi | custom
SDK_PACKAGE_SOURCE=pypi
SDK_INDEX_URL=
SDK_EXTRA_INDEX_URL=

# Optional alternate runtime env file to upload to the VM.
# By default run_gcp.sh uploads the local .env from this sample directory.
GCP_RUNTIME_ENV_FILE=

# Optional HSM/KMS settings if you use PERSONALIZE_ANCHOR=hsm
COMPUTE_SERVICE_ACCOUNT=
HSM_KMS_KEY=
HSM_KMS_ENDPOINT=
HSM_KMS_CREDENTIALS=
HSM_KMS_LOCATION=your-kms-location
HSM_KMS_KEY_RING=agents
HSM_KMS_KEY_NAME=helloworld
HSM_KMS_USE_HSM=0
