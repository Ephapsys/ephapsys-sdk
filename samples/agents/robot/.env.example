# Ephapsys Ops Center production API base URL.
# Use this production endpoint for the public SDK and samples.
AOC_BASE_URL=https://api.ephapsys.com

# Organization ID for your Ephapsys account.
# Get this from the Ephapsys web app after signing up and creating your organization.
AOC_ORG_ID=org_xxxxxxxxx

# Provisioning token used by the SDK to exchange for a short-lived device token at runtime.
# Generate this in the Ephapsys web app under your organization token/settings area.
AOC_PROVISIONING_TOKEN=boot_xxxxxxxxx

# Modulation token used by ./push.sh to register models, publish them, and create templates.
# Generate this in the Ephapsys web app under your organization token/settings area.
AOC_MODULATION_TOKEN=mod_xxxxxxxxx

# Human-readable label to use when creating the robot agent template.
# Choose this locally; it becomes the template label visible in the Ephapsys web app.
AGENT_TEMPLATE_NAME="Agent Template Name"

# Optional per-model labels and repos used by ./push.sh.
# Set these if you want the robot sample to keep a distinct template lineage
# separate from other sample or experiment templates in AOC.
ROBOT_TTS_REPO=microsoft/speecht5_tts
ROBOT_TTS_NAME="Robot TTS Model"
ROBOT_VOCODER_REPO=microsoft/speecht5_hifigan
ROBOT_VOCODER_NAME="Robot Vocoder Model"
ROBOT_STT_REPO=openai/whisper-tiny.en
ROBOT_STT_NAME="Robot STT Model"
ROBOT_LANGUAGE_REPO=Qwen/Qwen3.5-0.8B
ROBOT_LANGUAGE_NAME="Robot Language Model"
ROBOT_EMBEDDING_REPO=sentence-transformers/all-MiniLM-L6-v2
ROBOT_EMBEDDING_NAME="Robot Embedding Model"
ROBOT_VISION_REPO=hustvl/yolos-base
ROBOT_VISION_NAME="Robot Vision Model"
ROBOT_ENABLE_WORLD_MODEL=0
ROBOT_WORLD_REPO=facebook/vjepa2-vitl-fpc64-256
ROBOT_WORLD_NAME="Robot World Model"

# Agent template ID for the robot sample runtime.
# Get this after creating the template in Ephapsys, or leave it blank until that step is done.
AGENT_TEMPLATE_ID=agent_demo

# Optional model template IDs written back by ./push.sh for observability.
ROBOT_TTS_TEMPLATE_ID=
ROBOT_VOCODER_TEMPLATE_ID=
ROBOT_STT_TEMPLATE_ID=
ROBOT_LANGUAGE_TEMPLATE_ID=
ROBOT_EMBEDDING_TEMPLATE_ID=
ROBOT_VISION_TEMPLATE_ID=
ROBOT_WORLD_TEMPLATE_ID=

# Personalization anchor for the local runtime.
# Use 'none' for local development; use tpm, tee, dsim, or hsm for stronger production anchors.
PERSONALIZE_ANCHOR=none # dev/demo only; for production use tpm, tee, dsim, or hsm

# Local log verbosity for the SDK/runtime.
# Increase this when debugging the robot sample locally.
EPHAPSYS_LOG_LEVEL=WARNING

# Hugging Face token used when registering or downloading provider-backed model templates.
# Create this from your Hugging Face account settings if the selected repo requires it.
HF_TOKEN=hf_xxxxxxxxxxxx
